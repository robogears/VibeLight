<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required for the born-in-keychain client identity (SecKeyCreateRandomKey
	     with kSecAttrIsPermanent) to write to the data-protection keychain.
	     MUST be $(AppIdentifierPrefix)-prefixed: on device, automatic signing's
	     provisioning profile only grants <TeamID>.* groups, so a bare group is
	     rejected ("doesn't match the entitlements file's keychain-access-groups").
	     Xcode substitutes the prefix at build time (→ <TeamID>.com.vibelight.ios);
	     the Simulator doesn't enforce access groups, so it works there too. The
	     app uses no explicit kSecAttrAccessGroup, so items land in this default. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.vibelight.ios</string>
	</array>
</dict>
</plist>
